# Copy to .env, keep mode 0600, and never commit the real token.
INSPACE_API_URL=https://api.inspace.cloud
INSPACE_API_TOKEN=
INSPACE_LOCATION=bkk01
# Required positive decimal integer; CCM startup fails closed when absent.
INSPACE_BILLING_ACCOUNT_ID=
INSPACE_NETWORK_UUID=
# An unused private IPv4 inside the VPC subnet. kube-vip advertises this address
# for the RKE2 API (6443) and registration endpoint (9345).
INSPACE_CONTROL_PLANE_VIP=
# Inclusive 16-256-address RFC1918 range reserved only for Cilium LoadBalancer
# IPAM. Exclude every address in this range from InSpace VM and NLB allocation
# first; the current InSpace API cannot create that reservation for you.
INSPACE_PRIVATE_LOAD_BALANCER_POOL_START=
INSPACE_PRIVATE_LOAD_BALANCER_POOL_STOP=
INSPACE_FIREWALL_UUID=
INSPACE_AMD_HOST_POOL_UUID=
INSPACE_STORAGE_POOL_UUID=
INSPACE_OS_NAME=ubuntu
INSPACE_OS_VERSION=24.04
INSPACE_RESERVE_PUBLIC_IPV4=true

# Remote mutations stay blocked unless both values are deliberately enabled
# for an isolated-account live lifecycle run.
INSPACE_ALLOW_REMOTE_MUTATIONS=false
INSPACE_RUN_LIVE_TESTS=false
