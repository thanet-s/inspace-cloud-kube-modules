INSPACE_API_BASE_URL=https://api.inspace.cloud
INSPACE_API_TOKEN=
INSPACE_CLUSTER_NAME=example-rke2
INSPACE_DEFAULT_NODECLASS=ubuntu-workers-intel
INSPACE_SECRET_NAMESPACE=karpenter
INSPACE_LOCATION=bkk01
# Exact InSpace VPC and canonical private RKE2 supervisor VIP for this
# controller. Every InSpaceNodeClass must use these same immutable identities.
INSPACE_NETWORK_UUID=
INSPACE_CONTROL_PLANE_VIP=
# Exact inclusive 16-256-address RFC1918 Service VIP pool configured in every
# InSpaceNodeClass. It must contain only usable VPC hosts, exclude the supervisor
# VIP and fixed 10.42.0.0/16 + 10.43.0.0/16 networks, and contain no VM addresses.
INSPACE_PRIVATE_LOAD_BALANCER_POOL_START=10.0.0.200
INSPACE_PRIVATE_LOAD_BALANCER_POOL_STOP=10.0.0.219
INSPACE_ALLOW_REMOTE_MUTATIONS=false

# Required only by the explicitly gated live test.
INSPACE_RUN_LIVE_TESTS=false
INSPACE_BILLING_ACCOUNT_ID=
# Existing default-deny firewall with VPC + 10.42.0.0/16 inbound and any
# outbound coverage for TCP, UDP, and ICMP, and no public inbound rule. Tests
# never change its rules.
INSPACE_FIREWALL_UUID=
INSPACE_AMD_HOST_POOL_UUID=6976fdc8-4492-465b-bd16-9ad5f6b00b03
