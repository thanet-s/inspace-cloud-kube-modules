apiVersion: karpenter.inspace.cloud/v1alpha1
kind: InSpaceNodeClass
metadata:
  name: {{ karpenter_node_class_name }}
spec:
  clusterName: {{ cluster_name }}
  billingAccountID: {{ inspace_billing_account_id }}
  location: {{ inspace_location }}
  networkUUID: {{ inspace_network_uuid }}
  privateLoadBalancerPool:
    start: "{{ private_load_balancer_pool_start }}"
    stop: "{{ private_load_balancer_pool_stop }}"
  reservePublicIPv4: true
  firewallUUID: {{ bootstrap_result.firewallUUID }}
  imageSelector:
    osName: ubuntu
    osVersion: "24.04"
  rootDiskGiB: {{ karpenter_root_disk_gib }}
  bootstrapCache:
    directDownload: {{ bootstrap_direct_download | bool | ternary('true', 'false') }}
{% if not bootstrap_direct_download | bool %}
    address: "{{ bootstrap_result.bootstrapCacheAddress }}"
    caBundle: {{ bootstrap_result.bootstrapCacheCABundle | to_json }}
{% endif %}
  rke2:
    version: {{ rke2_version }}
    skipOSUpgrade: {{ skip_os_upgrade | bool | ternary('true', 'false') }}
    server: {{ bootstrap_result.privateRegistrationEndpoint }}
    tokenSecretRef:
      name: inspace-rke2-agent-token
      key: token
  sshUsername: {{ ssh_username }}
  sshPublicKey: {{ ssh_public_key_text | to_json }}
---
apiVersion: karpenter.sh/v1
kind: NodePool
metadata:
  name: {{ karpenter_node_pool_name }}
spec:
  limits:
    cpu: {{ karpenter_cpu_limit | to_json }}
    memory: {{ karpenter_memory_limit }}
  template:
    spec:
      nodeClassRef:
        group: karpenter.inspace.cloud
        kind: InSpaceNodeClass
        name: {{ karpenter_node_class_name }}
      requirements:
        - key: inspace.cloud/instance-family
          operator: In
          values: {{ karpenter_instance_families | to_json }}
        - key: inspace.cloud/instance-cpu
          operator: Gt
          values: [{{ karpenter_min_cpu_exclusive | to_json }}]
        - key: inspace.cloud/host-class
          operator: In
          values: [amd-epyc]
        - key: karpenter.sh/capacity-type
          operator: In
          values: [on-demand]
        - key: kubernetes.io/arch
          operator: In
          values: [amd64]
        - key: kubernetes.io/os
          operator: In
          values: [linux]
  disruption:
    consolidationPolicy: WhenEmpty
    consolidateAfter: {{ karpenter_consolidate_after }}
